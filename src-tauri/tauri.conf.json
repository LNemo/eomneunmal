{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "없는말",
  "version": "0.1.0",
  "identifier": "app.eomneunmal.desktop",
  "build": {
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset:; style-src 'self' 'unsafe-inline'; connect-src 'self'; script-src 'self'"
    },
    "windows": [
      {
        "label": "main",
        "title": "없는말",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "없는말 지적",
        "width": 420,
        "height": 220,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focusable": false,
        "visible": false,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "copyright": "Copyright © 2026 없는말 contributors"
  }
}
